<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="?android:attr/windowBackground">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00695C" />

    <TextView
        android:id="@+id/tvVentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ventilation"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <ImageView
        android:id="@+id/ivFanIcon"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_fan"
        android:padding="20dp"
        android:background="@drawable/color_circle"
        android:backgroundTint="#1A00695C"
        app:layout_constraintTop_toBottomOf="@id/tvVentTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvFanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stopped"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivFanIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSpeedPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="50%"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#00695C"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvFanStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/sbFanSpeed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:max="100"
        android:progress="50"
        android:progressTint="#00695C"
        android:thumbTint="#00695C"
        app:layout_constraintTop_toBottomOf="@id/tvSpeedPercent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/sbFanSpeed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAuto"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AUTO"
            android:layout_margin="4dp"
            android:backgroundTint="#4D00695C"
            android:textColor="#00695C" />

        <Button
            android:id="@+id/btnNight"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NIGHT"
            android:layout_margin="4dp"
            android:backgroundTint="#4D00695C"
            android:textColor="#00695C" />

        <Button
            android:id="@+id/btnTurbo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TURBO"
            android:layout_margin="4dp"
            android:backgroundTint="#4D00695C"
            android:textColor="#00695C" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>