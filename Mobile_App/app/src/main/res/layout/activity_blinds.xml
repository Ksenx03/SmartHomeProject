<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00695C" />

    <TextView
        android:id="@+id/tvBlindsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Window Blinds"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:id="@+id/windowFrame"
        android:layout_width="200dp"
        android:layout_height="250dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#E3F2FD"
        app:layout_constraintTop_toBottomOf="@id/tvBlindsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/blindsView"
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:background="#78909C" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Closed: 50%"
        android:layout_marginTop="20dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/windowFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <SeekBar
        android:id="@+id/sbBlinds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="50"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/sbBlinds">

        <Button android:id="@+id/btnOpen" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Open" android:layout_margin="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btnClosed" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Closed" android:layout_margin="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn30" android:layout_width="0dp" android:layout_columnWeight="1" android:text="30%" android:layout_margin="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn60" android:layout_width="0dp" android:layout_columnWeight="1" android:text="60%" android:layout_margin="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>